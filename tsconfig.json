{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["app/components/*"],
      "@screens/*": ["app/screens/*"],
      "@hooks/*": ["app/hooks/*"],
      "@utils/*": ["app/utils/*"],
      "@context/*": ["app/context/*"],
      "@navigation/*": ["app/navigation/*"],
      "@types/*": ["app/types/*"],
      "@assets/*": ["assets/*"]
    }
  }
} 