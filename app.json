{
  "expo": {
    "name": "MyCycle",
    "slug": "my-cycle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourusername.mycycle"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.yourusername.mycycle"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "A menstrual cycle and health tracking app.",
    "primaryColor": "#FF6B6B"
  }
} 